{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonJS",
    // "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node", "passport"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
