{
  "name": "horse-racing-api",
  "version": "1.0.0",
  "description": "Express REST API with Drizzle ORM, PostgreSQL, and JWT auth",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "start": "node dist/app.js",
    "build": "npx tsc",
    "db:push": "npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "format:check": "npx prettier --check .",
    "format:write": "npx prettier --write .",
    "lint": "npx eslint ."
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.21.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.4"
  }
}
